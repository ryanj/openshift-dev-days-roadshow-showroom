  "ignoreWords": [
    "adoc",
    "xref",
    "asciidoc",
    "imagesdir",
    "rhdh",
    "rhdp",
    "sonarqube",
    "argocd",
    "copypaste",
    "devmode"
  ],
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "*.min.js",
    "*.min.css",
    "www/**"
  ],
  "overrides": [
    {
      "filename": "**/*.adoc",
      "ignoreRegExpList": [
        "/^\\s*----[\\s\\S]*?^\\s*----\\s*$/gm",
        "/^\\s*\\+\\+\\+\\+[\\s\\S]*?^\\s*\\+\\+\\+\\+\\s*$/gm",
        "\\[source,.*\\]",
        "\\[.*,role=.*\\]",
        "\\+\\+\\+.*\\+\\+\\+",
        "^\\[.*\\]$",
        "`[^`]*`",
        "^\\|.*\\|$",
        "^====+$",
        "^----+$",
        "^\\.\\.\\.\\.+$",
        "^\\*\\*\\*\\*+$",
        "^<.*>$",
        "xref:.*\\[.*\\]",
        "image::.*\\[.*\\]",
        "image:.*\\[.*\\]",
        "include::.*\\[.*\\]",
        "link:.*\\[.*\\]",
        "ifdef::.*\\[\\]",
        "ifndef::.*\\[\\]",
        "endif::.*\\[\\]",
        "^:.*:.*$"
      ]
    }
  ],
  "dictionaries": [
    "softwareTerms",
    "node",
    "html",
    "css",
    "bash"
  ]
}
